# ════════════════════════════════════════════════════════════════
#  Pick ONE mode with MODE, then fill only that mode's block.
# ════════════════════════════════════════════════════════════════
#   managed     = agent connects to a panel (recommended; multi-node)
#   standalone  = single node, local user management, NO panel
MODE=managed

# Traffic + device sampling interval, seconds (both modes).
STATS_INTERVAL=60

# ── MANAGED mode ─ this is all you need ─────────────────────────
# From the panel's "Install" screen. The panel is the single source of truth:
# REALITY keys/dest, the TLS domain (incl. issuing the cert), and nginx SNI
# routing are all configured in the panel and applied by the agent. To enable
# TLS-Vision, just set the node's "TLS domain" in the panel — the agent tells
# the acme sidecar and the cert is issued automatically. Nothing else goes here.
PANEL_URL=https://panel.example.com
NODE_TOKEN=replace-with-node-token

# ── STANDALONE mode only ─ leave blank in managed mode ──────────
# The agent builds BOTH the Xray config and the nginx SNI routing from these.
# Generate a keypair: docker run --rm ghcr.io/xtls/xray-core:26.6.27 x25519
DOMAIN=                                # TLS domain (enables TLS-Vision + its cert)
ADDRESS=                               # public host/IP shown in share links
REALITY_SERVER_NAME=www.microsoft.com  # REALITY SNI (usually the dest's host)
REALITY_DEST=www.microsoft.com:443     # real site REALITY borrows its handshake from
REALITY_PRIVATE_KEY=                   # from x25519 (Private key)
REALITY_PUBLIC_KEY=                    # from x25519 (Public key) — used in share links
REALITY_SHORT_ID=                      # any hex, e.g. openssl rand -hex 8

# ── Automatic TLS ───────────────────────────────────────────────
# The acme sidecar issues + renews a cert whenever a TLS domain is set — from the
# panel (managed) or DOMAIN above (standalone). HTTP-01 on port 80, so the domain
# must resolve publicly to this host. No DOMAIN needed here for managed nodes.
# ACME_EMAIL is optional — a random one is generated if left blank.
# ACME_EMAIL=you@example.com
# ACME_SERVER=letsencrypt              # or letsencrypt_test for staging

# ── Optional image overrides ────────────────────────────────────
# XRAY_IMAGE=ghcr.io/xtls/xray-core:26.6.27
# NGINX_IMAGE=nginx:1.30.3-alpine
# ACME_IMAGE=neilpang/acme.sh:latest
