# HOST port published on the machine, mapped to the container's fixed :8088.
# Direct access: http://<server-ip>:<PANEL_PORT>. A reverse proxy (e.g. Nginx
# Proxy Manager) connects to the container's :8088 over the Docker network, so
# this port only matters for direct host access.
PANEL_PORT=8088

# Bootstrap admin, created on first boot only. The password SEEDS that first
# account; afterwards the database is authoritative, so a password you change in
# the panel sticks across restarts and is not reverted to this value. Still
# REQUIRED and must be strong: >=8 chars with an uppercase, lowercase, digit and
# special character.
PANEL_ADMIN_USER=admin
PANEL_ADMIN_PASS=

# Secret that signs admin/portal session cookies AND keys the at-rest encryption
# of secret DB fields (REALITY private keys, TOTP secrets, the Telegram token).
# REQUIRED; >=16 chars; keep it stable — rotating it invalidates sessions and
# makes existing encrypted data unrecoverable. Generate: openssl rand -hex 32
PANEL_JWT_SECRET=

# ── Optional first-run seeds (all editable later in the panel) ───
# Public base URL used in subscription links + node install command.
# You can set it here, or leave it and set it in the panel (Settings).
# PANEL_PUBLIC_URL=https://panel.example.com
#
# Local-testing only: allow a weak admin password.
# PANEL_ALLOW_WEAK_PASS=1
