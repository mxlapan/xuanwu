# build the node agent
FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -buildvcs=false -trimpath -ldflags "-s -w" -o /agent ./cmd/agent

# runtime needs docker CLI to restart xray and run statsquery
FROM alpine:3.22
RUN apk add --no-cache docker-cli
COPY --from=build /agent /usr/local/bin/agent
ENTRYPOINT ["/usr/local/bin/agent"]
